#!/usr/bin/env python3
"""
SVcustos — Evaluación del modelo entrenado
===========================================
Evalúa el modelo sobre el conjunto test y genera:
- Matriz de confusión
- Accuracy, Precision, Recall, F1 por clase
- Reporte completo en JSON

Uso:
  python evaluate.py --level n16 --model models/svcustos_n16_resnet34_*.pth

DOI:   https://doi.org/10.21428/39829d0b.981b7276
Autor: Juan Antonio Lloret Egea
Licencia: CC BY-NC-ND 4.0
"""

import argparse
import json
import sys
from pathlib import Path
from datetime import datetime

import numpy as np
import yaml

try:
    import torch
    import torch.nn as nn
    from torchvision import datasets, models, transforms
except ImportError:
    print("Error: PyTorch no instalado.")
    sys.exit(1)

try:
    from sklearn.metrics import (
        confusion_matrix, classification_report,
        accuracy_score, precision_recall_fscore_support
    )
except ImportError:
    print("Error: scikit-learn no instalado.")
    print("Instala con: pip install scikit-learn")
    sys.exit(1)


def evaluate(level, model_path, config_dir="config", no_gpu=False):
    # Load config
    config_path = Path(config_dir) / f"{level}.yaml"
    with open(config_path) as f:
        cfg = yaml.safe_load(f)

    n = cfg["level"]["n"]
    data_dir = Path("data") / f"n{n}" / "test"

    if not data_dir.exists():
        print(f"Error: Test data not found at {data_dir}")
        sys.exit(1)

    # Device
    device = torch.device("cpu") if no_gpu else \
        torch.device("cuda:0" if torch.cuda.is_available() else "cpu")

    print(f"═══ SVcustos Model Evaluation ═══")
    print(f"  Level: n={n}")
    print(f"  Model: {model_path}")
    print(f"  Device: {device}")
    print()

    # Load model
    checkpoint = torch.load(model_path, map_location=device, weights_only=False)
    class_names = checkpoint["class_names"]
    num_classes = len(class_names)
    model_name = cfg["training"]["model"]

    if model_name == "resnet34":
        model = models.resnet34()
    elif model_name == "resnet50":
        model = models.resnet50()
    else:
        model = models.resnet18()

    model.fc = nn.Linear(model.fc.in_features, num_classes)
    model.load_state_dict(checkpoint["model_state_dict"])
    model = model.to(device)
    model.eval()

    # Data
    test_transform = transforms.Compose([
        transforms.Resize(224),
        transforms.ToTensor(),
        transforms.Normalize([0.485, 0.456, 0.406],
                             [0.229, 0.224, 0.225])
    ])
    test_dataset = datasets.ImageFolder(str(data_dir.parent / "test"), test_transform)
    test_loader = torch.utils.data.DataLoader(
        test_dataset, batch_size=32, shuffle=False, num_workers=4
    )

    print(f"  Test images: {len(test_dataset)}")
    print(f"  Classes: {class_names}")
    print()

    # Predict
    all_preds = []
    all_labels = []

    with torch.no_grad():
        for inputs, labels in test_loader:
            inputs = inputs.to(device)
            outputs = model(inputs)
            _, preds = torch.max(outputs, 1)
            all_preds.extend(preds.cpu().numpy())
            all_labels.extend(labels.cpu().numpy())

    all_preds = np.array(all_preds)
    all_labels = np.array(all_labels)

    # Metrics
    acc = accuracy_score(all_labels, all_preds)
    cm = confusion_matrix(all_labels, all_preds)
    precision, recall, f1, support = precision_recall_fscore_support(
        all_labels, all_preds, average=None, labels=range(num_classes)
    )

    errors = int(np.sum(all_preds != all_labels))
    total = len(all_labels)
    error_rate = errors / total

    # Print results
    print(f"  ═══ RESULTADOS ═══")
    print(f"  Accuracy:   {acc:.4f} ({acc*100:.2f}%)")
    print(f"  Error rate: {error_rate:.4f} ({errors}/{total})")
    print()

    print(f"  Matriz de confusión:")
    # Header
    header = "  {:>15s}".format("") + "".join(f"  {c:>13s}" for c in class_names)
    print(header)
    for i, row in enumerate(cm):
        row_str = "  {:>15s}".format(class_names[i])
        for val in row:
            row_str += f"  {val:>13d}"
        print(row_str)
    print()

    print(f"  Per-class metrics:")
    print(f"  {'Class':>15s}  {'Precision':>10s}  {'Recall':>10s}  {'F1':>10s}  {'Support':>10s}")
    for i, cls in enumerate(class_names):
        print(f"  {cls:>15s}  {precision[i]:>10.4f}  {recall[i]:>10.4f}  {f1[i]:>10.4f}  {support[i]:>10d}")
    print()

    # Save report
    results_dir = Path("results")
    results_dir.mkdir(exist_ok=True)
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")

    report = {
        "level": f"n{n}",
        "document": cfg["level"]["document"],
        "model": model_name,
        "timestamp": timestamp,
        "test_images": total,
        "accuracy": acc,
        "error_rate": error_rate,
        "errors": errors,
        "confusion_matrix": cm.tolist(),
        "class_names": class_names,
        "per_class": {
            cls: {
                "precision": float(precision[i]),
                "recall": float(recall[i]),
                "f1": float(f1[i]),
                "support": int(support[i])
            }
            for i, cls in enumerate(class_names)
        },
        "training_best_val_acc": checkpoint.get("best_val_acc", None),
        "doi": "https://doi.org/10.21428/39829d0b.981b7276",
        "author": "Juan Antonio Lloret Egea",
    }

    report_path = results_dir / f"eval_n{n}_{timestamp}.json"
    with open(report_path, "w") as f:
        json.dump(report, f, indent=2)
    print(f"  Report saved: {report_path}")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="SVcustos — Evaluate trained model")
    parser.add_argument("--level", required=True, choices=["n16", "n25", "n36"])
    parser.add_argument("--model", required=True, help="Path to .pth model file")
    parser.add_argument("--config-dir", default="config")
    parser.add_argument("--no-gpu", action="store_true")
    args = parser.parse_args()

    evaluate(args.level, args.model, args.config_dir, args.no_gpu)
